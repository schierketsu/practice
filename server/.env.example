DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-long-random-string-in-production"
PORT=3001
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Локально SMTP часто не доступен: письмо только в консоль сервера, UI заявки работает.
# MAIL_MODE="log"

# VK WorkSpace / Mail.ru SMTP (пароль приложения; нужен MAIL_MODE=smtp или не задавать MAIL_MODE)
SMTP_HOST="smtp.mail.ru"
SMTP_USER="info@studprakt.ru"
SMTP_PASS=""
MAIL_FROM="info@studprakt.ru"

# Рекомендуется 587 + STARTTLS, если 465 не проходит
SMTP_PORT="587"
SMTP_SECURE="false"

# Резолвить smtp.mail.ru только в IPv4 (по умолчанию да; при ETIMEDOUT по IPv6 это часто лечит ситуацию)
# SMTP_IPV4_ONLY="false"

# Таймаут подключения, мс
# SMTP_CONNECTION_TIMEOUT_MS="25000"
