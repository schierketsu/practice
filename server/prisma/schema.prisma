generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  /// Относительный путь от uploads/, например resumes/xxx.pdf
  resumeStoredPath   String?
  resumeOriginalName String?
  resumeUploadedAt   DateTime?
  role            Role      @default(USER)
  blocked         Boolean   @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  reviews         Review[]
}

model Company {
  id           Int      @id @default(autoincrement())
  name         String
  logo         String
  description  String
  technologies Json
  sector       String
  contacts     String
  city         String
  /// Список вузов (JSON-массив строк), по которым фильтруется карта
  universities Json
  faculty      String
  lat          Float
  lng          Float
  reviews      Review[]
}

model TechnologyIcon {
  id       Int     @id @default(autoincrement())
  /// Имя технологии как в company.technologies (точное совпадение)
  name     String  @unique
  /// Относительный путь: uploads/tech-icons/... (null — иконка не загружена)
  iconPath String?
}

/// Справочник вузов (имена совпадают со строками в company.universities JSON)
model University {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  faculties Faculty[]
}

model Faculty {
  id           Int        @id @default(autoincrement())
  name         String
  universityId Int
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([universityId, name])
}

model Review {
  id            Int          @id @default(autoincrement())
  companyId     Int
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorDisplay String
  text          String
  rating        Int
  employment    String
  location      String
  periodLabel   String?
  status        ReviewStatus @default(PENDING)
  createdAt     DateTime     @default(now())
}
