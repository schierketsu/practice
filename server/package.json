{
  "name": "practice-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:migrate-health": "node scripts/migrate-health.mjs",
    "db:repair-migration-log": "prisma db execute --file prisma/sql/repair_prisma_migrations.sql --schema prisma/schema.prisma",
    "db:remove-chto-migration-log": "prisma db execute --file prisma/sql/remove_chto_to_migration_log.sql --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^22.10.5",
    "prisma": "^6.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
